# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" uses a Railway volume; "r2" uses Cloudflare R2
STORAGE_BACKEND=local
# Filesystem path when STORAGE_BACKEND=local (mount a Railway volume here)
STORAGE_LOCAL_PATH=/storage

# Cloudflare R2 (only required when STORAGE_BACKEND=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Google Cloud Vision (OCR) ─────────────────────────────────────────────────
# Option A: paste the full service account JSON content here
GOOGLE_CLOUD_CREDENTIALS_JSON=
# Option B: path to a service account JSON file (standard GCP ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# The service account needs the "Cloud Vision API User" role.

# ── Gemini ────────────────────────────────────────────────────────────────────
# Google AI Studio or Vertex API key — used for all Gemini calls
GOOGLE_API_KEY=
# Override model IDs if needed (defaults shown)
# GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash-lite
# GEMINI_PRO_MODEL=gemini-2.5-pro

# ── Google Drive (optional) ───────────────────────────────────────────────────
# Full JSON string of service account credentials, or path to the JSON file
# The service account needs Drive readonly scope on the target folder.
GDRIVE_SERVICE_ACCOUNT_JSON=

# ── Worker tuning ─────────────────────────────────────────────────────────────
# Max simultaneous invoices processed per worker process
WORKER_CONCURRENCY=15
# Seconds to sleep between Postgres queue polls
WORKER_POLL_INTERVAL_SECONDS=2

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_FILES_PER_JOB=200
MAX_FILE_SIZE_MB=20
MAX_TOTAL_UPLOAD_MB=500

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
